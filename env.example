PORT=3333
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agendservicos?schema=public"
CORS_ORIGIN="http://localhost:3000"
LOG_LEVEL="info"

# JWT — gere segredos longos e aleatórios em produção (ex: openssl rand -hex 64)
JWT_SECRET="seu_jwt_secret"
JWT_REFRESH_SECRET="seu_jwt_refresh_secret"
JWT_ACCESS_EXPIRES_IN="4h"
JWT_REFRESH_EXPIRES_IN="2d"

# Mail — configure o remetente padrão para os emails enviados pela aplicação
MAIL_FROM_NAME="Suporte meu App"
MAIL_FROM_EMAIL="suporte@meuapp.com.br"

# Setup para email — configure com as credenciais do seu provedor de email (mailtrap)
MAIL_ENABLED=true
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario_mailtrap
SMTP_PASS=sua_senha_mailtrap
SMTP_FROM_NAME=seu_nome
SMTP_FROM_EMAIL=noreply@agendservicos.com